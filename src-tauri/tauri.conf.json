{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "factbook",
  "version": "0.1.0",
  "identifier": "com.michalwa.factbook",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "factbook",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "cli": {
      "description": "factbook",
      "args": [
        {
          "short": "f",
          "name": "file",
          "description": "Journal file",
          "takesValue": true,
          "required": true
        }
      ]
    }
  }
}
